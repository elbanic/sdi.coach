# AWS Configuration
export AWS_REGION=us-west-2
# Option 1: Use an AWS SSO profile (recommended)
export AWS_PROFILE=your_profile_here
# Option 2: Direct credentials
# export AWS_ACCESS_KEY_ID=your_access_key_here
# export AWS_SECRET_ACCESS_KEY=your_secret_key_here

# SDI Coach Model Configuration
# Interviewer: Claude Sonnet 4.5 (fast, conversational)
export SDICOACH_INTERVIEWER_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Feedback: Claude Opus 4.6 (deep analysis)
export SDICOACH_FEEDBACK_MODEL=us.anthropic.claude-opus-4-6-v1
# TTS: Qwen3-TTS MLX model
export SDICOACH_TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-0.6B-Base-8bit

# Logging Configuration
export SDICOACH_LOG_LEVEL=INFO
